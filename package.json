{
  "name": "01kit-chrome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "01Kit Chrome extension and product site.",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "store:assets": "npm run build && node scripts/generate-store-assets.mjs",
    "sync:site-docs": "node scripts/sync-site-docs.mjs",
    "video": "npm run video:motion:zh && npm run video:motion:en && npm run video:demo:zh && npm run video:demo:en",
    "video:motion:zh": "remotion render remotion/index.ts 01KitMotionZh site/public/media/01kit-motion-zh.mp4 --codec=h264 --crf=24 --overwrite",
    "video:motion:en": "remotion render remotion/index.ts 01KitMotionEn site/public/media/01kit-motion-en.mp4 --codec=h264 --crf=24 --overwrite",
    "video:demo:zh": "remotion render remotion/index.ts 01KitDemoZh site/public/media/01kit-demo-zh.mp4 --codec=h264 --crf=24 --overwrite",
    "video:demo:en": "remotion render remotion/index.ts 01KitDemoEn site/public/media/01kit-demo-en.mp4 --codec=h264 --crf=24 --overwrite",
    "video:poster": "npm run video:poster:motion:zh && npm run video:poster:motion:en && npm run video:poster:demo:zh && npm run video:poster:demo:en",
    "video:poster:motion:zh": "remotion still remotion/index.ts 01KitMotionZh site/public/media/01kit-motion-zh-poster.png --frame=120 --overwrite",
    "video:poster:motion:en": "remotion still remotion/index.ts 01KitMotionEn site/public/media/01kit-motion-en-poster.png --frame=120 --overwrite",
    "video:poster:demo:zh": "remotion still remotion/index.ts 01KitDemoZh site/public/media/01kit-demo-zh-poster.png --frame=110 --overwrite",
    "video:poster:demo:en": "remotion still remotion/index.ts 01KitDemoEn site/public/media/01kit-demo-en-poster.png --frame=110 --overwrite",
    "build:site": "npm run sync:site-docs && vite build --config site/vite.config.ts",
    "prepare:site": "npm run build && npm run zip && node scripts/copy-extension-zip.mjs",
    "deploy:site": "npm run prepare:site && npm run build:site && wrangler deploy",
    "check": "wxt prepare && tsc --noEmit && npm run build && npm run build:site"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@wxt-dev/module-react": "^1.2.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "wxt": "^0.20.25"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.451",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "remotion": "^4.0.451",
    "typescript": "^5.9.3",
    "wrangler": "^4.80.0"
  }
}
